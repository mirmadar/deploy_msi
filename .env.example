# Скопируйте в .env и подставьте свои значения. Файл .env в git не коммитить.
# Используется при запуске: docker-compose up

# === PostgreSQL (сервис db) ===
POSTGRES_DB=msiadmin
POSTGRES_USER=msiadmin
POSTGRES_PASSWORD=

# DATABASE_URL для backend (хост БД в Docker = db)
DATABASE_URL=postgresql://msiadmin:ВАШ_ПАРОЛЬ@db:5432/msiadmin?schema=public

# JWT
PRIVATE_KEY=
JWT_EXPIRES_IN=24h

# SMTP (письма с сайта)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
# Опционально, если нужны отдельные ящики для заявок/заказов:
# CALLBACK_RECIPIENT_EMAIL=
# SERVICE_ORDER_RECIPIENT_EMAIL=
# COMPANY_EMAIL=

# Базовый URL приложения (для писем и ссылок). На сервере — ваш домен.
APP_BASE_URL=http://localhost:3002

# S3 (хранилище файлов)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Elasticsearch (в Docker уже настроен)
ELASTICSEARCH_NODE=http://elasticsearch:9200
# На сервере порт 9200 проброшен только на 127.0.0.1 — из интернета ES не доступен.

# CORS (опционально). Через запятую, например: https://site.com,https://admin.site.com
# CORS_ORIGINS=

# URL API для фронтов. На сервере — адрес вашего backend (домен или IP:3000)
NEXT_PUBLIC_API_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:3000
